VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"
VITE_BRAND_NAME="UEFNToolkit"
VITE_CANONICAL_URL="https://uefntoolkit.com"
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"
BRAND_NAME="UEFNToolkit"
BRAND_CANONICAL_DOMAIN="uefntoolkit.com"
# For running SQL via terminal (psql) against your Supabase project.
# Format:
# postgresql://postgres:<db_password>@db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL="postgresql://postgres:<db_password>@db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require"
# Optional: Data Supabase bridge (App -> Data)
DATA_SUPABASE_URL="https://<your-data-project-ref>.supabase.co"
DATA_SUPABASE_SERVICE_ROLE_KEY="<your-data-service-role-key>"
INTERNAL_BRIDGE_SECRET="<shared-strong-random-secret>"
LOOKUP_DATA_TIMEOUT_MS="4500"
SERVING_CACHE_TTL_SECONDS="120"
DISCOVERY_DPPI_PROXY_STRICT="true"
OPENAI_API_KEY="<your-openai-api-key>"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TRANSLATION_MODEL="gpt-4.1-mini"
NVIDIA_API_KEY="<your-nvidia-api-key>"
NVIDIA_LOOKUP_MODEL="moonshotai/kimi-k2.5"
# Optional: comma-separated doc paths for incremental support memory sync.
# Defaults to `docs` when not set.
SUPPORT_RAG_PATHS="docs"

# -----------------------------------------------------------------------------
# Stripe + Commerce Foundation (test mode)
# -----------------------------------------------------------------------------
APP_BASE_URL="http://localhost:8080"

# Stripe secret keys
STRIPE_SECRET_KEY="<your-stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<your-stripe-webhook-signing-secret>"

# Stripe Price IDs
STRIPE_PRICE_PRO_MONTHLY="<price-id-pro-monthly>"
STRIPE_PRICE_PACK_250="<price-id-pack-250>"
STRIPE_PRICE_PACK_650="<price-id-pack-650>"
STRIPE_PRICE_PACK_1400="<price-id-pack-1400>"

# Commerce gateway hardening
COMMERCE_GATEWAY_SECRET="<strong-random-secret>"
COMMERCE_GATEWAY_ENFORCE="true"
COMMERCE_INTERNAL_SECRET="<strong-random-secret>"
COMMERCE_RATE_LIMIT_ENABLED="true"
COMMERCE_RATE_LIMIT_EXECUTE_PER_MINUTE="24"
COMMERCE_RATE_LIMIT_REVERSE_PER_MINUTE="30"
COMMERCE_RATE_LIMIT_SUB_CHECKOUT_PER_HOUR="6"
COMMERCE_RATE_LIMIT_PACK_CHECKOUT_PER_HOUR="12"
COMMERCE_RATE_LIMIT_WEBHOOK_PER_MINUTE="240"
