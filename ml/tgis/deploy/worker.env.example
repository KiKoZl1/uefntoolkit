SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Use Supabase pooler URI (IPv4-friendly). URL-encode password if needed.
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_ENCODED_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
FAL_API_KEY=YOUR_FAL_KEY
RUNPOD_API_KEY=YOUR_RUNPOD_KEY

AI_TOOLKIT_RUNNER=/workspace/ai-toolkit/run.py
AI_TOOLKIT_PYTHON=/workspace/.venv_aitk/bin/python

TGIS_WORKER_HOST=hetzner-cx22-01
TGIS_WORKER_SOURCE=hetzner-cx22
TGIS_CONFIG_PATH=ml/tgis/configs/base.yaml
